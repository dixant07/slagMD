units           real
dimension       3
boundary        p p p
atom_style      charge


# simulation box
region          box block 0 17.750683960000 0 17.750683960000 0 17.750683960000
create_box      2 box

create_atoms    1 random 261 12345 box overlap 1.5 maxtry 1000
create_atoms    2 random 392 45678 box overlap 1.5 maxtry 1000

mass 1   26.98153860
mass 2   15.99900000


set type 1 charge  1.4175
set type 2 charge -0.945

# potential
pair_style      born/coul/long 8.0 10.0 
kspace_style    pppm 1.0e-4

# coefficients
pair_coeff 1 1 0.078239 0.068000 1.570400 324.062027 0.0
pair_coeff 1 2 0.197912 0.172000 2.606700 797.495048 0.0
pair_coeff 2 2 0.317586 0.276000 3.643000 1962.274140 0.0



neighbor        2.0 bin
neigh_modify    delay 0 every 1 check yes
timestep        1.0
thermo          1000
thermo_style    custom step temp press vol density pe ke etotal


neighbor        2.0 bin
neigh_modify    delay 0 every 1 check yes
timestep        1.0
thermo          1000
thermo_style    custom step temp press vol density pe ke etotal


# initial velocity and relaxation
minimize        1.0e-4 1.0e-8 10000 100000
velocity        all create 300.0 4928459 dist gaussian
reset_timestep  0


